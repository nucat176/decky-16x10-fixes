{
  "name": "decky-16x10-fixes",
  "version": "0.1.0",
  "description": "Decky Loader plugin that scans your Steam library and installs curated 16:10 fixes.",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "package": "pnpm build && ./scripts/package-plugin.sh"
  },
  "keywords": [
    "decky",
    "steam-deck",
    "steamos",
    "aspect-ratio",
    "16:10"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nucat176/decky-16x10-fixes.git"
  },
  "homepage": "https://github.com/nucat176/decky-16x10-fixes",
  "bugs": {
    "url": "https://github.com/nucat176/decky-16x10-fixes/issues"
  },
  "author": "Adam Foosaner",
  "license": "MIT",
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.0",
    "@rollup/rollup-linux-x64-musl": "^4.53.3",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "rollup": "^4.53.3",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "react-icons": "^5.3.0",
    "tslib": "^2.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
